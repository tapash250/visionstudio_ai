generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ==================== CORE USER SYSTEM ====================

model User {
  id            String    @id @default(cuid())
  email         String    @unique
  emailVerified DateTime? @map("email_verified")
  passwordHash  String?   @map("password_hash")
  name          String?
  avatar        String?

  // Auth providers
  accounts      Account[]
  sessions      Session[]

  // Preferences
  preferences   Json?     @default("{}")
  theme         String    @default("dark")
  language      String    @default("en")

  // Mature content (18+)
  matureEnabled Boolean   @default(false) @map("mature_enabled")
  matureConsent MatureConsent?
  maturePin     String?   @map("mature_pin")

  // Rate limiting / abuse
  trustScore    Int       @default(100) @map("trust_score")
  bannedAt      DateTime? @map("banned_at")
  banReason     String?   @map("ban_reason")

  // Timestamps
  createdAt     DateTime  @default(now()) @map("created_at")
  updatedAt     DateTime  @updatedAt @map("updated_at")

  // Relations
  projects      Project[]
  generationJobs GenerationJob[]
  editJobs      EditJob[]
  animationJobs AnimationJob[]
  promptHistory PromptHistory[]
  devices       Device[]
  moderationLogs ModerationLog[]

  @@map("users")
}

model Account {
  id                String  @id @default(cuid())
  userId            String  @map("user_id")
  type              String
  provider          String
  providerAccountId String  @map("provider_account_id")
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@map("accounts")
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique @map("session_token")
  userId       String   @map("user_id")
  expires      DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("sessions")
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
  @@map("verification_tokens")
}

model MatureConsent {
  id            String   @id @default(cuid())
  userId        String   @unique @map("user_id")
  consentGiven  Boolean  @map("consent_given")
  consentDate   DateTime @map("consent_date")
  verifiedMethod String  @map("verified_method") // "credit_card", "id_verify", "age_estimation"
  ipAddress     String?  @map("ip_address")
  sessionTimeout Int     @default(30) @map("session_timeout") // minutes
  lastAccessed  DateTime @map("last_accessed")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("mature_consents")
}

// ==================== PROJECTS & MEDIA ====================

model Project {
  id          String   @id @default(cuid())
  userId      String   @map("user_id")
  title       String
  description String?

  // Media
  thumbnailUrl String? @map("thumbnail_url")
  sourceUrl   String?  @map("source_url")
  resultUrl   String?  @map("result_url")

  // Type
  type        ProjectType @default(GENERATION)
  status      ProjectStatus @default(DRAFT)

  // Privacy
  isPublic    Boolean  @default(false) @map("is_public")
  isMature    Boolean  @default(false) @map("is_mature")
  isEncrypted Boolean  @default(false) @map("is_encrypted")

  // Metadata
  metadata    Json?    @default("{}")
  tags        String[]

  // Timestamps
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  // Relations
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  generationJob GenerationJob?
  editJob     EditJob?
  animationJob AnimationJob?

  @@index([userId, createdAt])
  @@index([status, type])
  @@map("projects")
}

enum ProjectType {
  GENERATION
  EDIT
  ANIMATION
  BATCH
}

enum ProjectStatus {
  DRAFT
  QUEUED
  PROCESSING
  COMPLETED
  FAILED
  CANCELLED
}

// ==================== AI JOBS ====================

model GenerationJob {
  id          String   @id @default(cuid())
  projectId   String   @unique @map("project_id")
  userId      String   @map("user_id")

  // Prompt
  prompt      String   @db.Text
  negativePrompt String? @map("negative_prompt") @db.Text
  enhancedPrompt String? @map("enhanced_prompt") @db.Text

  // Config
  model       String   @default("flux-dev")
  style       String?
  aspectRatio String   @default("9:16") @map("aspect_ratio")
  seed        Int?
  steps       Int      @default(30)
  cfgScale    Float    @default(7.5) @map("cfg_scale")

  // Batch
  batchSize   Int      @default(1) @map("batch_size")
  batchIndex  Int      @default(0) @map("batch_index")

  // Results
  resultUrls  String[] @map("result_urls")
  selectedUrl String?  @map("selected_url")

  // Processing
  status      JobStatus @default(PENDING)
  priority    Int      @default(5)
  workerId    String?  @map("worker_id")
  startedAt   DateTime? @map("started_at")
  completedAt DateTime? @map("completed_at")
  error       String?

  // Cost/performance tracking
  computeTime Float?   @map("compute_time") // seconds
  gpuType     String?  @map("gpu_type")

  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@index([status, priority])
  @@index([userId, createdAt])
  @@map("generation_jobs")
}

model EditJob {
  id          String   @id @default(cuid())
  projectId   String   @unique @map("project_id")
  userId      String   @map("user_id")

  // Source
  sourceUrl   String   @map("source_url")

  // Operation
  operation   EditOperation
  maskUrl     String?  @map("mask_url")

  // Config
  prompt      String?  @db.Text
  strength    Float    @default(0.75)
  preserveFace Boolean @default(true) @map("preserve_face")

  // Results
  resultUrl   String?  @map("result_url")
  beforeAfter Json?    @map("before_after")

  // Processing
  status      JobStatus @default(PENDING)
  priority    Int      @default(5)
  workerId    String?  @map("worker_id")
  startedAt   DateTime? @map("started_at")
  completedAt DateTime? @map("completed_at")
  error       String?

  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@index([status])
  @@map("edit_jobs")
}

model AnimationJob {
  id          String   @id @default(cuid())
  projectId   String   @unique @map("project_id")
  userId      String   @map("user_id")

  // Source
  sourceUrl   String   @map("source_url")
  sourceType  String   @default("image") @map("source_type") // image, video

  // Animation config
  animationType String @map("animation_type") // face_blink, smile, head_motion, talking, lip_sync, zoom, parallax, dance, pan, bg_motion
  duration    Int      @default(3) // seconds
  fps         Int      @default(24)

  // Optional audio for lip sync
  audioUrl    String?  @map("audio_url")

  // Results
  resultUrl   String?  @map("result_url")
  previewUrl  String?  @map("preview_url")
  format      String   @default("mp4") // mp4, webm, gif

  // Processing
  status      JobStatus @default(PENDING)
  priority    Int      @default(5)
  workerId    String?  @map("worker_id")
  startedAt   DateTime? @map("started_at")
  completedAt DateTime? @map("completed_at")
  error       String?

  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@index([status])
  @@map("animation_jobs")
}

enum JobStatus {
  PENDING
  QUEUED
  PROCESSING
  COMPLETED
  FAILED
  CANCELLED
}

enum EditOperation {
  INPAINT
  OUTPAINT
  REMOVE_OBJECT
  REMOVE_OUTFIT
  REMOVE_BACKGROUND
  REPLACE_BACKGROUND
  FACE_RESTORE
  FACE_ENHANCE
  SKIN_RETOUCH
  LIGHTING
  SHARPEN
  REPLACE_CLOTHING
  CHANGE_STYLE
  COLOR_SWAP
  ADD_ACCESSORY
  GLAMOUR
  BOUDOIR
  EDITORIAL
}

// ==================== STYLE PRESETS ====================

model StylePreset {
  id          String   @id @default(cuid())
  name        String   @unique
  label       String
  category    String
  description String?

  // Style config
  promptPrefix  String? @map("prompt_prefix") @db.Text
  promptSuffix  String? @map("prompt_suffix") @db.Text
  negativePrompt String? @map("negative_prompt") @db.Text

  // Visual
  thumbnailUrl  String? @map("thumbnail_url")
  colorAccent   String? @map("color_accent")

  // Settings
  model         String  @default("flux-dev")
  cfgScale      Float   @default(7.0) @map("cfg_scale")
  steps         Int     @default(30)

  // Mature flag
  isMature      Boolean @default(false) @map("is_mature")

  // Stats
  useCount      Int     @default(0) @map("use_count")

  createdAt     DateTime @default(now()) @map("created_at")

  @@index([category])
  @@index([isMature])
  @@map("style_presets")
}

// ==================== PROMPT HISTORY ====================

model PromptHistory {
  id        String   @id @default(cuid())
  userId    String   @map("user_id")
  prompt    String   @db.Text
  negativePrompt String? @map("negative_prompt") @db.Text
  type      String   @default("generation") // generation, edit, animation

  // Context
  model     String?
  style     String?
  resultUrl String?  @map("result_url")

  createdAt DateTime @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, createdAt])
  @@map("prompt_history")
}

// ==================== DEVICES & PUSH ====================

model Device {
  id           String   @id @default(cuid())
  userId       String   @map("user_id")

  // Device info
  fingerprint  String   @unique
  deviceName   String?  @map("device_name")
  deviceType   String?  @map("device_type") // mobile, tablet, desktop
  os           String?
  browser      String?

  // Push
  pushToken    String?  @map("push_token")
  pushEnabled  Boolean  @default(true) @map("push_enabled")

  // PWA
  installed    Boolean  @default(false)
  installDate  DateTime? @map("install_date")

  // Rate limiting
  lastActive   DateTime @default(now()) @map("last_active")
  requestCount Int      @default(0) @map("request_count")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([fingerprint])
  @@index([userId])
  @@map("devices")
}

// ==================== MODERATION ====================

model ModerationLog {
  id          String   @id @default(cuid())
  userId      String   @map("user_id")

  // Content
  contentType String   @map("content_type") // image, video, prompt
  contentUrl  String?  @map("content_url")
  prompt      String?  @db.Text

  // Moderation result
  action      ModerationAction
  score       Float?   // AI confidence
  categories  String[] // detected violation categories
  reason      String?

  // Review
  reviewedBy  String?  @map("reviewed_by")
  reviewedAt  DateTime? @map("reviewed_at")
  appealStatus String? @map("appeal_status")

  createdAt   DateTime @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([action, createdAt])
  @@index([userId])
  @@map("moderation_logs")
}

enum ModerationAction {
  ALLOWED
  FLAGGED
  BLOCKED
  SHADOW_BANNED
  USER_BANNED
  AUTO_APPROVED
}
