# VisionStudio AI — Root Environment Configuration
# Copy this file to .env and fill in your values

# ============================================
# FRONTEND
# ============================================
NEXT_PUBLIC_API_URL=http://localhost:8000
NEXTAUTH_URL=http://localhost:3000
NEXTAUTH_SECRET=change-this-to-a-32-character-random-string

# OAuth Providers
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=

# ============================================
# BACKEND
# ============================================
DATABASE_URL=postgresql+asyncpg://visionstudio:visionstudio@localhost:5432/visionstudio
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_URL=redis://localhost:6379/0

JWT_SECRET_KEY=change-this-to-a-64-character-random-string-minimum
JWT_ALGORITHM=HS256

# Storage (Cloudflare R2)
STORAGE_PROVIDER=r2
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET_NAME=visionstudio-media
R2_PUBLIC_URL=

# GPU Worker
GPU_WORKER_URL=http://localhost:8001

# Moderation
MODERATION_ENABLED=true

# App
ENV=development
CORS_ORIGINS=http://localhost:3000,https://visionstudio.app
MAX_UPLOAD_SIZE=50
RATE_LIMIT_RPM=60

# ============================================
# GPU WORKER
# ============================================
CUDA_VISIBLE_DEVICES=0
HF_HOME=/app/cache
