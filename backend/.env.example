# Database
DATABASE_URL=postgresql+asyncpg://user:password@db:5432/visionstudio

# Redis
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_URL=redis://redis:6379/0

# Auth
JWT_SECRET_KEY=your-super-secret-jwt-key-change-in-production
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=15
JWT_REFRESH_TOKEN_EXPIRE_DAYS=7

# OAuth
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=

# Storage (Cloudflare R2 / AWS S3)
STORAGE_PROVIDER=r2
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET_NAME=visionstudio-media
R2_PUBLIC_URL=

# AI GPU Workers
GPU_WORKER_URL=http://gpu-worker:8001
RUNPOD_API_KEY=
MODAL_TOKEN_ID=
MODAL_TOKEN_SECRET=

# Moderation
MODERATION_ENABLED=true
AWS_REKOGNITION_ACCESS_KEY=
AWS_REKOGNITION_SECRET_KEY=

# App
ENV=development
CORS_ORIGINS=http://localhost:3000,https://visionstudio.app
MAX_UPLOAD_SIZE=50
RATE_LIMIT_RPM=60
